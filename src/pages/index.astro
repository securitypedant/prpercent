<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Lift Calculator</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  </head>
  <body class="bg-light">
    <div class="container py-4">
      <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6" style="max-width: 400px;">
          <h1 class="text-center mb-3 fs-4">Lift Calculator</h1>

          <!-- Input Section -->
          <div class="card shadow-sm mb-3">
            <div class="card-body p-3">
              <div class="mb-2">
                <label for="liftName" class="form-label small mb-1">Lift</label>
                <input type="text" class="form-control form-control-sm" id="liftName" placeholder="Bench Press" />
              </div>
              <div class="mb-3">
                <label for="liftWeight" class="form-label small mb-1">Weight (lbs)</label>
                <input type="number" class="form-control form-control-sm" id="liftWeight" placeholder="195" min="0" step="0.1" />
              </div>
              <button class="btn btn-primary btn-sm w-100" id="calculateBtn">Calculate</button>
              <div class="mt-2 text-center small" id="saveStatus"></div>
            </div>
          </div>

          <!-- Saved Lifts Section -->
          <div class="card shadow-sm mb-3" id="savedLiftsCard" style="display: none;">
            <div class="card-body p-3">
              <label class="form-label small mb-1">Saved Lifts</label>
              <div class="input-group input-group-sm">
                <select class="form-select" id="savedLiftsSelect">
                  <option value="">Select a lift...</option>
                </select>
                <button class="btn btn-outline-danger" type="button" id="deleteBtn">Delete</button>
              </div>
            </div>
          </div>

          <!-- Results Section -->
          <div id="resultsSection" style="display: none;">
            <h6 class="text-center mb-2 text-muted" id="resultsTitle"></h6>
            <div id="percentagesList"></div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script is:inline src="/app.js"></script>
  </body>
</html>
