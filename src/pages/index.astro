<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Weightlifting Percentage Calculator</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  </head>
  <body class="bg-light">
    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
          <h1 class="text-center mb-4">Weightlifting Percentage Calculator</h1>
          
          <!-- Input Section -->
          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <h5 class="card-title">Enter Your Personal Best</h5>
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="liftName" class="form-label">Lift Name</label>
                  <input type="text" class="form-control" id="liftName" placeholder="e.g., Bench Press" />
                </div>
                <div class="col-md-6">
                  <label for="liftWeight" class="form-label">Weight (lbs)</label>
                  <input type="number" class="form-control" id="liftWeight" placeholder="e.g., 195" min="0" step="0.1" />
                </div>
              </div>
              <button class="btn btn-primary mt-3 w-100" id="calculateBtn">Calculate Percentages</button>
              <div class="mt-2 text-center" id="saveStatus"></div>
            </div>
          </div>

          <!-- Saved Lifts Section -->
          <div class="card shadow-sm mb-4" id="savedLiftsCard" style="display: none;">
            <div class="card-body">
              <h5 class="card-title">Saved Lifts</h5>
              <div id="savedLiftsList" class="d-flex flex-wrap gap-2"></div>
              <button class="btn btn-outline-danger btn-sm mt-3" id="clearAllBtn">Clear All</button>
            </div>
          </div>

          <!-- Results Section -->
          <div id="resultsSection" style="display: none;">
            <h3 class="text-center mb-3" id="resultsTitle"></h3>
            <div class="row g-3" id="percentagesList"></div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script is:inline src="/app.js"></script>
  </body>
</html>
